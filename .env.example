# Backend API base URL (no trailing slash). Defaults to http://localhost:5000
# - Local dev (.env / .env.development): http://localhost:5000
# - Production build (.env.production):  https://billbookbackend-n4m8.onrender.com
VITE_API_BASE_URL=http://localhost:5000

# Firebase config is no longer used for auth (auth is now email/password + backend
# OTP). Kept here only for reference; safe to remove.
# VITE_FIREBASE_API_KEY=your_api_key_here
# VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
# VITE_FIREBASE_PROJECT_ID=your_project_id_here
# VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
# VITE_FIREBASE_APP_ID=your_app_id_here
